<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.login.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #1F3864;">

    <stylesheets>
        <URL value="@../styles/styles.css"/>
    </stylesheets>

    <!-- Logo y título -->
    <VBox alignment="CENTER" spacing="10"
          style="-fx-padding: 60 0 40 0;">
        <Label text="🎡"
               style="-fx-font-size: 64;"/>
        <Label text="TECH-PARK UQ"
               style="-fx-font-size: 28; -fx-font-weight: bold;
                      -fx-text-fill: #FFD700; -fx-letter-spacing: 3;"/>
        <Label text="Sistema de Gestión Inteligente"
               style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.7);"/>
    </VBox>

    <!-- Card de selección de rol -->
    <VBox alignment="CENTER" spacing="16"
          style="-fx-background-color: rgba(255,255,255,0.08);
                 -fx-background-radius: 16;
                 -fx-border-color: rgba(255,255,255,0.15);
                 -fx-border-radius: 16;
                 -fx-padding: 40 60 40 60;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 4);">

        <Label text="Selecciona tu rol para continuar"
               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);
                      -fx-padding: 0 0 10 0;"/>

        <Button fx:id="btnAdmin"
                text="⚙  Administrador"
                onAction="#ingresarComoAdmin"
                maxWidth="Infinity"
                style="-fx-background-color: #2E75B6;
                       -fx-text-fill: white;
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-padding: 14 40;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-min-width: 280;"/>

        <Button fx:id="btnVisitante"
                text="🎢  Visitante"
                onAction="#ingresarComoVisitante"
                maxWidth="Infinity"
                style="-fx-background-color: #27AE60;
                       -fx-text-fill: white;
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-padding: 14 40;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-min-width: 280;"/>

        <Button fx:id="btnOperador"
                text="🔧  Operador"
                onAction="#ingresarComoOperador"
                maxWidth="Infinity"
                style="-fx-background-color: #F39C12;
                       -fx-text-fill: white;
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-padding: 14 40;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-min-width: 280;"/>
    </VBox>

    <!-- Footer -->
    <Label text="Universidad del Quindío · Estructuras de Datos 2026-1"
           style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.4);
                  -fx-padding: 40 0 20 0;"/>

</VBox>