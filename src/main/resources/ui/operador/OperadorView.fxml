<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.operador.OperadorController"
            prefWidth="1280" prefHeight="720">

    <stylesheets>
        <URL value="@../styles/styles.css"/>
    </stylesheets>

    <left>
        <VBox prefWidth="200"
              style="-fx-background-color: #4A235A; -fx-padding: 20; -fx-spacing: 8;">

            <Label text="🔧 OPERADOR"
                   style="-fx-text-fill: #FFD700; -fx-font-size: 14;
                          -fx-font-weight: bold; -fx-padding: 0 0 10 5;"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <Button text="🎢 Mi Atracción"      styleClass="sidebar-btn" onAction="#mostrarAtraccion" maxWidth="Infinity"/>
            <Button text="👥 Cola de Visitantes" styleClass="sidebar-btn" onAction="#mostrarCola"      maxWidth="Infinity"/>
            <Button text="⚙ Estado y Revisión"  styleClass="sidebar-btn" onAction="#mostrarEstado"    maxWidth="Infinity"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>

            <!-- Tarjeta de perfil -->
            <VBox spacing="6"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius: 10; -fx-padding: 12 10;">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane>
                        <javafx.scene.shape.Circle
                                fx:id="avatarCirculo"
                                radius="20"
                                fill="#7D3C98"
                                stroke="rgba(255,255,255,0.3)"
                                strokeWidth="1.5"/>
                        <javafx.scene.image.ImageView
                                fx:id="avatarImagen"
                                fitWidth="40" fitHeight="40"/>
                        <Label fx:id="lblInicial"
                               text="O"
                               style="-fx-text-fill: white;
                                      -fx-font-weight: bold;
                                      -fx-font-size: 16;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblNombreOperador"
                               text="Operador"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 11;
                                      -fx-font-weight: bold;"/>
                        <Label fx:id="lblZonaOperador"
                               text="Sin zona"
                               style="-fx-text-fill: #D7BDE2;
                                      -fx-font-size: 10;"/>
                    </VBox>
                </HBox>

                <HBox spacing="6">
                    <Button text="✏ Perfil"
                            onAction="#editarPerfil"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white; -fx-font-size: 10;
                                   -fx-padding: 5 8; -fx-background-radius: 5;
                                   -fx-cursor: hand;"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="🚪"
                            onAction="#cerrarSesion"
                            style="-fx-background-color: rgba(192,57,43,0.7);
                                   -fx-text-fill: white; -fx-font-size: 12;
                                   -fx-padding: 5 8; -fx-background-radius: 5;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="panelCentral"
                   style="-fx-background-color: #F0F4F8;"/>
    </center>
</BorderPane>