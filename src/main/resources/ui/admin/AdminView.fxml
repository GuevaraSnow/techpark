<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.admin.AdminController"
            prefWidth="1280" prefHeight="720">

    <stylesheets>
        <URL value="@../../styles/styles.css"/>
    </stylesheets>

    <left>
        <VBox prefWidth="200"
              style="-fx-background-color: #1F3864; -fx-padding: 20; -fx-spacing: 8;">

            <!-- Título -->
            <Label text="⚙ ADMINISTRADOR"
                   style="-fx-text-fill: #FFD700; -fx-font-size: 14;
                          -fx-font-weight: bold; -fx-padding: 0 0 10 5;"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <!-- Botones de navegación -->
            <Button text="🗺 Zonas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarZonas"
                    maxWidth="Infinity"/>
            <Button text="🎢 Atracciones"
                    styleClass="sidebar-btn"
                    onAction="#mostrarAtracciones"
                    maxWidth="Infinity"/>
            <Button text="👥 Empleados"
                    styleClass="sidebar-btn"
                    onAction="#mostrarEmpleados"
                    maxWidth="Infinity"/>
            <Button text="🔔 Alertas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarAlertas"
                    maxWidth="Infinity"/>
            <Button text="📊 Estadísticas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarEstadisticas"
                    maxWidth="Infinity"/>
            <Button text="🗾 Mapa"
                    styleClass="sidebar-btn"
                    onAction="#mostrarMapa"
                    maxWidth="Infinity"/>

            <!-- Espaciador para empujar perfil al fondo -->
            <VBox VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.15);"/>

            <!-- Tarjeta de perfil al fondo -->
            <VBox fx:id="perfilCard"
                  spacing="6"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius: 10;
                         -fx-padding: 12 10;
                         -fx-cursor: hand;">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <!-- Avatar círculo con inicial -->
                    <StackPane>
                        <javafx.scene.shape.Circle
                                fx:id="avatarCirculo"
                                radius="20"
                                fill="#2E75B6"
                                stroke="rgba(255,255,255,0.3)"
                                strokeWidth="1.5"/>
                        <Label fx:id="lblInicial"
                               text="A"
                               style="-fx-text-fill: white;
                                      -fx-font-weight: bold;
                                      -fx-font-size: 16;"/>
                    </StackPane>

                    <VBox spacing="2">
                        <Label fx:id="lblNombreAdmin"
                               text="Administrador"
                               style="-fx-text-fill: white;
                                      -fx-font-size: 11;
                                      -fx-font-weight: bold;"/>
                        <Label text="Administrador"
                               style="-fx-text-fill: #FFD700;
                                      -fx-font-size: 10;"/>
                    </VBox>
                </HBox>

                <HBox spacing="6">
                    <Button text="✏ Perfil"
                            onAction="#editarPerfil"
                            style="-fx-background-color: rgba(255,255,255,0.15);
                                   -fx-text-fill: white;
                                   -fx-font-size: 10;
                                   -fx-padding: 5 8;
                                   -fx-background-radius: 5;
                                   -fx-cursor: hand;"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                    <Button text="🚪"
                            onAction="#cerrarSesion"
                            style="-fx-background-color: rgba(192,57,43,0.7);
                                   -fx-text-fill: white;
                                   -fx-font-size: 12;
                                   -fx-padding: 5 8;
                                   -fx-background-radius: 5;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="panelCentral"
                   style="-fx-background-color: #F0F4F8;"/>
    </center>

</BorderPane>