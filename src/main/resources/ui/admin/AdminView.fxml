<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.admin.AdminController"
            prefWidth="1280"
            prefHeight="720">

    <left>
        <VBox styleClass="sidebar"
              prefWidth="200"
              style="-fx-background-color: #1F3864; -fx-padding: 20; -fx-spacing: 8;">

            <Label text="⚙ ADMINISTRADOR"
                   styleClass="sidebar-titulo"
                   style="-fx-text-fill: #FFD700; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 0 0 10 5;"/>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

            <Button text="🗺 Zonas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarZonas"
                    maxWidth="Infinity"/>

            <Button text="🎢 Atracciones"
                    styleClass="sidebar-btn"
                    onAction="#mostrarAtracciones"
                    maxWidth="Infinity"/>

            <Button text="👥 Empleados"
                    styleClass="sidebar-btn"
                    onAction="#mostrarEmpleados"
                    maxWidth="Infinity"/>

            <Button text="🔔 Alertas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarAlertas"
                    maxWidth="Infinity"/>

            <Button text="📊 Estadísticas"
                    styleClass="sidebar-btn"
                    onAction="#mostrarEstadisticas"
                    maxWidth="Infinity"/>

            <Button text="🗾 Mapa"
                    styleClass="sidebar-btn"
                    onAction="#mostrarMapa"
                    maxWidth="Infinity"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="panelCentral"
                   styleClass="panel-central"/>
    </center>

    <stylesheets>
        <URL value="@../../styles/styles.css"/>
    </stylesheets>

</BorderPane>