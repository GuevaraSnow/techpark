<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.admin.AdminController"
            prefWidth="1280"
            prefHeight="720">

    <!-- Sidebar -->
    <left>
        <VBox spacing="10"
              prefWidth="200"
              style="-fx-background-color: #1F3864; -fx-padding: 20;">

            <Label text="⚙ ADMINISTRADOR"
                   style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>

            <Separator/>

            <Button text="🗺 Zonas"
                    onAction="#mostrarZonas"
                    maxWidth="Infinity"/>

            <Button text="🎢 Atracciones"
                    onAction="#mostrarAtracciones"
                    maxWidth="Infinity"/>

            <Button text="👥 Empleados"
                    onAction="#mostrarEmpleados"
                    maxWidth="Infinity"/>

            <Button text="🔔 Alertas"
                    onAction="#mostrarAlertas"
                    maxWidth="Infinity"/>

            <Button text="📊 Estadísticas"
                    onAction="#mostrarEstadisticas"
                    maxWidth="Infinity"/>

            <Button text="🗾 Mapa"
                    onAction="#mostrarMapa"
                    maxWidth="Infinity"/>

        </VBox>
    </left>

    <!-- Panel Central -->
    <center>
        <StackPane fx:id="panelCentral"
                   style="-fx-background-color: #F5F5F5;"/>
    </center>

</BorderPane>