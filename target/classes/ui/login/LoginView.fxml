<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.login.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #1F3864;"
      prefWidth="1280" prefHeight="720">

    <stylesheets>
        <URL value="@../styles/styles.css"/>
    </stylesheets>

    <!-- Logo y título -->
    <VBox alignment="CENTER" spacing="10"
          style="-fx-padding: 50 0 30 0;">
        <Label text="🎡"
               style="-fx-font-size: 64;"/>
        <Label text="TECH-PARK UQ"
               style="-fx-font-size: 28; -fx-font-weight: bold;
                      -fx-text-fill: #FFD700; -fx-letter-spacing: 3;"/>
        <Label text="Sistema de Gestión Inteligente"
               style="-fx-font-size: 13;
                      -fx-text-fill: rgba(255,255,255,0.7);"/>
    </VBox>

    <!-- Card de login -->
    <VBox alignment="CENTER" spacing="14"
          style="-fx-background-color: rgba(255,255,255,0.08);
                 -fx-background-radius: 16;
                 -fx-border-color: rgba(255,255,255,0.15);
                 -fx-border-radius: 16;
                 -fx-padding: 40 60 40 60;
                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.3),20,0,0,4);">

        <Label text="Ingresa tus credenciales"
               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);
                      -fx-padding: 0 0 6 0;"/>

        <!-- Campo documento -->
        <TextField fx:id="txtDocumento"
                   promptText="Documento / Usuario"
                   style="-fx-background-color: rgba(255,255,255,0.12);
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: rgba(255,255,255,0.5);
                          -fx-background-radius: 8;
                          -fx-border-color: rgba(255,255,255,0.2);
                          -fx-border-radius: 8;
                          -fx-padding: 12 16;
                          -fx-font-size: 13;
                          -fx-min-width: 300;"/>

        <!-- Campo contraseña -->
        <PasswordField fx:id="txtPassword"
                       promptText="Contraseña"
                       style="-fx-background-color: rgba(255,255,255,0.12);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: rgba(255,255,255,0.5);
                              -fx-background-radius: 8;
                              -fx-border-color: rgba(255,255,255,0.2);
                              -fx-border-radius: 8;
                              -fx-padding: 12 16;
                              -fx-font-size: 13;
                              -fx-min-width: 300;"/>

        <!-- Mensaje de error -->
        <Label fx:id="lblError"
               text=""
               style="-fx-text-fill: #FF6B6B; -fx-font-size: 12;"/>

        <!-- Botón ingresar -->
        <Button fx:id="btnIngresar"
                text="Ingresar →"
                onAction="#ingresar"
                maxWidth="Infinity"
                style="-fx-background-color: #2E75B6;
                       -fx-text-fill: white;
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-padding: 12 40;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-min-width: 300;"/>

    </VBox>

    <!-- Hint de credenciales -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-padding: 24 0 0 0;">
        <Label text="💡 Credenciales de prueba:"
               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.5);"/>
        <Label text="Admin: admin / admin  |  Visitante: 1001234567 / 1001234567  |  Operador: 1011111111 / 1011111111"
               style="-fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.35);"/>
    </VBox>

    <!-- Footer -->
    <Label text="Universidad del Quindío · Estructuras de Datos 2026-1"
           style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.3);
                  -fx-padding: 20 0 0 0;"/>

</VBox>